{
  "expo": {
    "name": "CitySync",
    "slug": "citysync",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "citysync",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0E4F63"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bitpolpette.citysync",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CitySync usa la tua posizione per mostrarti i mezzi disponibili nelle vicinanze."
      }
    },
    "android": {
      "package": "com.bitpolpette.citysync",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CitySync usa la tua posizione per mostrarti i mezzi disponibili nelle vicinanze."
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "dbf10d3c-9af1-4765-96ed-1af686b36d8b"
      }
    },
    "owner": "bit-and-polpette"
  }
}
